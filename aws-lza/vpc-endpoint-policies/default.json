{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowFromOrg",
      "Effect": "Allow",
      "Principal": "*",
      "Action": "*",
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:PrincipalOrgID": "PLACEHOLDER_ORG_ID"
        }
      }
    }
  ]
}