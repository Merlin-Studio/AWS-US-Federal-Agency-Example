{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowRootAccount",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::PLACEHOLDER_ACCOUNT_ID_LogArchive:root"
      },
      "Action": "kms:*",
      "Resource": "*"
    },
    {
      "Sid": "AllowCloudtrail",
      "Effect": "Allow",
      "Principal": {"Service": "cloudtrail.amazonaws.com"},
      "Action": ["kms:GenerateDataKey*", "kms:DescribeKey"],
      "Resource": "*",
      "Condition": {"StringLike": {"aws:SourceArn": ["arn:aws:cloudtrail:*:PLACEHOLDER_ACCOUNT_ID_Management:trail/*", "arn:aws:cloudtrail:*:PLACEHOLDER_ACCOUNT_ID_LogArchive:trail/*"], "kms:EncryptionContext:aws:cloudtrail:arn": ["arn:aws:cloudtrail:*:PLACEHOLDER_ACCOUNT_ID_Management:trail/*", "arn:aws:cloudtrail:*:PLACEHOLDER_ACCOUNT_ID_LogArchive:trail/*"]}}    },
    {
      "Sid": "AllowConfig",
      "Effect": "Allow",
      "Principal": {"Service": "config.amazonaws.com"},
      "Action": ["kms:GenerateDataKey*", "kms:Decrypt", "kms:DescribeKey"],
      "Resource": "*",
      "Condition": {"StringEquals": {"aws:SourceOrgID": "PLACEHOLDER_ORG_ID"}}    },
    {
      "Sid": "AllowDeliverylogs",
      "Effect": "Allow",
      "Principal": {"Service": "delivery.logs.amazonaws.com"},
      "Action": ["kms:GenerateDataKey*", "kms:Decrypt", "kms:DescribeKey"],
      "Resource": "*",
      "Condition": {"StringEquals": {"aws:SourceOrgID": "PLACEHOLDER_ORG_ID"}}    },
    {
      "Sid": "AllowS3",
      "Effect": "Allow",
      "Principal": {"Service": "s3.amazonaws.com"},
      "Action": ["kms:GenerateDataKey*", "kms:Decrypt", "kms:DescribeKey"],
      "Resource": "*",
      "Condition": {"StringEquals": {"aws:SourceAccount": "PLACEHOLDER_ACCOUNT_ID_LogArchive"}}    }  ]
}